# Copy to deepseek_pilot/.env and paste your key. .env is gitignored — never commit it.
#
# Provider: OpenModel gateway (OpenAI-compatible). Docs:
#   https://docs.openmodel.ai/en/docs/getting-started/quickstart
# Auth is "Authorization: Bearer <key>" (OpenAI format). The runner calls
# {OPENMODEL_BASE_URL}/chat/completions.

OPENMODEL_API_KEY=om-paste-your-openmodel-key-here
OPENMODEL_BASE_URL=https://api.openmodel.ai/v1
# DeepSeek ids on this gateway (verified via /v1/models; both use the messages protocol):
#   deepseek-v4-flash  = bulk/cheap (use this)
#   deepseek-v4-pro    = stronger, for hard cases
# NOTE: "deepseek-chat" does NOT exist here -> "no channel available" 404.
OPENMODEL_MODEL=deepseek-v4-flash
